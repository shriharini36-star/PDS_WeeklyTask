   "source": [
    "def parse_csv(filename):\n",
    "    with open(filename,\"r\",buffering=8192) as file:\n",
    "        next(file)\n",
    "        for line in file:\n",
    "            line = line.strip()\n",
    "            if not line:\n",
    "                continue\n",
    "\n",
    "            yield line.split(\",\")"
   ]
  },
